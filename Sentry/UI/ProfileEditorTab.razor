@using OpenShock.Desktop.ModuleBase.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.IO.Compression
@using System.Text.Json
@implements IDisposable

<MudStack Spacing="3" Class="pa-4">

    <MudText Typo="Typo.h5">Profile Editor</MudText>

    @* Profile selector + new/delete *@
    <MudCard>
        <MudCardContent>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudSelect T="string" Label="Profile" Value="_selectedProfile"
                           Variant="Variant.Outlined" Dense="true" Style="max-width: 250px;"
                           ValueChanged="OnProfileSelected">
                    @foreach (var p in _profiles)
                    {
                        <MudSelectItem Value="@p">@p</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           OnClick="NewProfile" StartIcon="@Icons.Material.Filled.Add">
                    New
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick="DeleteProfile" Disabled="@(_profile is null)"
                           StartIcon="@Icons.Material.Filled.Delete">
                    Delete
                </MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                           OnClick="ExportProfile" Disabled="@(_profile is null)"
                           StartIcon="@Icons.Material.Filled.FileDownload">
                    Export
                </MudButton>
                <MudFileUpload T="IBrowserFile" Accept=".sentryprofile,.zip,.json" FilesChanged="ImportProfile"
                               MaximumFileCount="1" Style="margin: 0;">
                    <CustomContent Context="fileUpload">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.FileUpload"
                                   OnClick="@(() => fileUpload.OpenFilePickerAsync())">
                            Import
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>
            </MudStack>
        </MudCardContent>
    </MudCard>

    @if (_profile is not null)
    {
        @* Basic info *@
        <MudCard>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="6">
                        <MudTextField Value="_profile.Name" Label="Profile Name"
                                      ValueChanged="@((string v) => { _profile.Name = v; QueueSave(); })"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudTextField Value="_profile.ProcessName" Label="Process Name (optional)"
                                      ValueChanged="@((string? v) => { _profile.ProcessName = v; QueueSave(); })"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      HelperText="e.g. helldivers2, javaw" />
                    </MudItem>
                    <MudItem xs="2" Class="d-flex align-center">
                        <MudSwitch T="bool" Value="_profile.PerRegionCapture"
                                   ValueChanged="@((bool v) => { _profile.PerRegionCapture = v; QueueSave(); })"
                                   Label="Per-region capture" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="2" Class="d-flex align-center">
                        <MudSwitch T="bool" Value="_profile.ParallelDetection"
                                   ValueChanged="@((bool v) => { _profile.ParallelDetection = v; QueueSave(); })"
                                   Label="Parallel detection" Color="Color.Secondary" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @* Region Preview *@
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.h6">Region Preview</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.CameraAlt" Size="Size.Small"
                                       OnClick="CapturePreview" title="Capture screenshot for region preview" />
                    </MudStack>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Style="padding: 0;">
                <RegionPreview @ref="_regionPreview"
                               ImageDataUri="@_previewDataUri"
                               Regions="_regionItems"
                               OnRegionChanged="OnRegionDragged"
                               OnRegionSelected="OnRegionClicked"
                               PlaceholderText="Click the camera icon to capture a screenshot for region preview." />
            </MudCardContent>
        </MudCard>

        @* Detectors *@
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.h6">Detectors</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   OnClick="AddDetector" StartIcon="@Icons.Material.Filled.Add">
                            Add Detector
                        </MudButton>
                    </MudStack>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_profile.Detectors.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        No detectors configured. Click "Add Detector" to create one.
                    </MudAlert>
                }
                else
                {
                    <MudExpansionPanels MultiExpansion="true">
                        @for (var i = 0; i < _profile.Detectors.Count; i++)
                        {
                            var detector = _profile.Detectors[i];
                            var index = i;
                            var color = _regionColors[i % _regionColors.Length];

                            <MudExpansionPanel @bind-Expanded="detector._expanded"
                                               Style="@($"border-left: 4px solid {color};")">
                                <TitleContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.subtitle1">@(string.IsNullOrEmpty(detector.Name) ? "(unnamed)" : detector.Name)</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="@GetBackendColor(detector.Backend)">@detector.Backend</MudChip>
                                        <MudChip T="string" Size="Size.Small">@detector.EventType</MudChip>
                                        <MudSpacer />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                       Size="Size.Small" OnClick="() => RemoveDetector(index)"
                                                       title="Remove detector" />
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="4">
                                            <MudTextField Value="detector.Name" Label="Name"
                                                          ValueChanged="@((string v) => OnDetectorNameChanged(detector, v))"
                                                          Variant="Variant.Outlined" />
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudSelect T="DetectorBackendType" Value="detector.Backend"
                                                       ValueChanged="@((DetectorBackendType v) => { detector.Backend = v; QueueSave(); })"
                                                       Label="Backend" Variant="Variant.Outlined" Dense="true">
                                                @foreach (var bt in Enum.GetValues<DetectorBackendType>())
                                                {
                                                    <MudSelectItem Value="bt">@bt</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudTextField T="string" Value="detector.EventType"
                                                          ValueChanged="@((string v) => { detector.EventType = v; QueueSave(); })"
                                                          Label="Event Type" Variant="Variant.Outlined"
                                                          HelperText="e.g. death, damage, kill" />
                                        </MudItem>

                                        @* Region *@
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="mb-1">
                                                Region (normalized 0.0 – 1.0)
                                            </MudText>
                                        </MudItem>
                                        <MudItem xs="3">
                                            <MudNumericField T="float" Value="detector.Region.X" Label="X"
                                                             ValueChanged="@(v => OnRegionFieldChanged(detector, r => r.X = v))"
                                                             Variant="Variant.Outlined"
                                                             Min="0f" Max="1f" Step="0.01f" Format="F2" />
                                        </MudItem>
                                        <MudItem xs="3">
                                            <MudNumericField T="float" Value="detector.Region.Y" Label="Y"
                                                             ValueChanged="@(v => OnRegionFieldChanged(detector, r => r.Y = v))"
                                                             Variant="Variant.Outlined"
                                                             Min="0f" Max="1f" Step="0.01f" Format="F2" />
                                        </MudItem>
                                        <MudItem xs="3">
                                            <MudNumericField T="float" Value="detector.Region.Width" Label="Width"
                                                             ValueChanged="@(v => OnRegionFieldChanged(detector, r => r.Width = v))"
                                                             Variant="Variant.Outlined"
                                                             Min="0f" Max="1f" Step="0.01f" Format="F2" />
                                        </MudItem>
                                        <MudItem xs="3">
                                            <MudNumericField T="float" Value="detector.Region.Height" Label="Height"
                                                             ValueChanged="@(v => OnRegionFieldChanged(detector, r => r.Height = v))"
                                                             Variant="Variant.Outlined"
                                                             Min="0f" Max="1f" Step="0.01f" Format="F2" />
                                        </MudItem>

                                        <MudItem xs="6">
                                            <MudSwitch T="bool" Value="detector.InvertMatch"
                                                       ValueChanged="@((bool v) => { detector.InvertMatch = v; QueueSave(); })"
                                                       Label="Invert Match (trigger when NOT detected)" Color="Color.Warning" />
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudSwitch T="bool" Value="detector.RequireClear"
                                                       ValueChanged="@((bool v) => { detector.RequireClear = v; QueueSave(); })"
                                                       Label="Require Clear (must stop matching before re-triggering)" Color="Color.Info" />
                                        </MudItem>

                                        @* Backend-specific settings *@
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="mb-1">Backend Settings</MudText>
                                            @switch (detector.Settings)
                                            {
                                                case OpenCvTemplateSettings tmpl:
                                                    <MudGrid Spacing="2">
                                                        <MudItem xs="8">
                                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                <MudTextField Value="tmpl.TemplatePath"
                                                                              ValueChanged="@((string v) => { tmpl.TemplatePath = v; QueueSave(); })"
                                                                              Label="Template Image"
                                                                              Variant="Variant.Outlined"
                                                                              HelperText="Relative to profile assets dir or absolute path" />
                                                                <MudFileUpload T="IBrowserFile" Accept=".png,.jpg,.jpeg,.bmp"
                                                                               FilesChanged="@(f => ImportTemplateImage(detector, f))"
                                                                               MaximumFileCount="1">
                                                                    <CustomContent Context="fileUpload">
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Image"
                                                                                       Color="Color.Primary" Size="Size.Small"
                                                                                       title="Pick template image"
                                                                                       OnClick="@(() => fileUpload.OpenFilePickerAsync())" />
                                                                    </CustomContent>
                                                                </MudFileUpload>
                                                            </MudStack>
                                                        </MudItem>
                                                        <MudItem xs="4">
                                                            <MudNumericField T="float" Value="tmpl.Threshold"
                                                                             ValueChanged="@((float v) => { tmpl.Threshold = v; QueueSave(); })"
                                                                             Label="Threshold" Variant="Variant.Outlined"
                                                                             Min="0f" Max="1f" Step="0.05f" Format="F2" />
                                                        </MudItem>
                                                    </MudGrid>
                                                    break;
                                                case OpenCvSiftSettings sift:
                                                    <MudGrid Spacing="2">
                                                        <MudItem xs="8">
                                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                <MudTextField Value="sift.TemplatePath"
                                                                              ValueChanged="@((string v) => { sift.TemplatePath = v; QueueSave(); })"
                                                                              Label="Template Image"
                                                                              Variant="Variant.Outlined"
                                                                              HelperText="Relative to profile assets dir or absolute path" />
                                                                <MudFileUpload T="IBrowserFile" Accept=".png,.jpg,.jpeg,.bmp"
                                                                               FilesChanged="@(f => ImportTemplateImage(detector, f))"
                                                                               MaximumFileCount="1">
                                                                    <CustomContent Context="fileUpload">
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Image"
                                                                                       Color="Color.Primary" Size="Size.Small"
                                                                                       title="Pick template image"
                                                                                       OnClick="@(() => fileUpload.OpenFilePickerAsync())" />
                                                                    </CustomContent>
                                                                </MudFileUpload>
                                                            </MudStack>
                                                        </MudItem>
                                                        <MudItem xs="6">
                                                            <MudNumericField T="float" Value="sift.RatioThreshold"
                                                                             ValueChanged="@((float v) => { sift.RatioThreshold = v; QueueSave(); })"
                                                                             Label="Lowe's Ratio Threshold" Variant="Variant.Outlined"
                                                                             Min="0.1f" Max="0.9f" Step="0.05f" Format="F2" />
                                                        </MudItem>
                                                        <MudItem xs="6">
                                                            <MudNumericField T="int" Value="sift.MinGoodMatches"
                                                                             ValueChanged="@((int v) => { sift.MinGoodMatches = v; QueueSave(); })"
                                                                             Label="Min Good Matches" Variant="Variant.Outlined"
                                                                             Min="3" Max="50" />
                                                        </MudItem>
                                                    </MudGrid>
                                                    break;
                                                case OcrSettings ocr:
                                                    <MudTextField Value="ocr.Pattern"
                                                                  ValueChanged="@((string v) => { ocr.Pattern = v; QueueSave(); })"
                                                                  Label="Regex Pattern" Variant="Variant.Outlined"
                                                                  HelperText="e.g. (?i)you died|killed in action" />
                                                    break;
                                                case HealthBarSettings hb:
                                                    <MudGrid Spacing="2">
                                                        <MudItem xs="4">
                                                            <MudSelect T="HealthBarOrientation" Value="hb.Orientation"
                                                                       ValueChanged="@((HealthBarOrientation v) => { hb.Orientation = v; QueueSave(); })"
                                                                       Label="Orientation" Variant="Variant.Outlined" Dense="true">
                                                                @foreach (var o in Enum.GetValues<HealthBarOrientation>())
                                                                {
                                                                    <MudSelectItem Value="o">@o</MudSelectItem>
                                                                }
                                                            </MudSelect>
                                                        </MudItem>
                                                        <MudItem xs="4">
                                                            <MudNumericField T="int" Value="hb.BrightnessThreshold"
                                                                             ValueChanged="@((int v) => { hb.BrightnessThreshold = v; QueueSave(); })"
                                                                             Label="Brightness Threshold (0–255)" Variant="Variant.Outlined"
                                                                             Min="0" Max="255" />
                                                        </MudItem>
                                                        <MudItem xs="4">
                                                            <MudNumericField T="float" Value="hb.SliceFillRatio"
                                                                             ValueChanged="@((float v) => { hb.SliceFillRatio = v; QueueSave(); })"
                                                                             Label="Slice Fill Ratio" Variant="Variant.Outlined"
                                                                             Min="0f" Max="1f" Step="0.05f" Format="F2"
                                                                             HelperText="Fraction of perpendicular pixels needed to count a slice as filled" />
                                                        </MudItem>
                                                        <MudItem xs="6">
                                                            <MudNumericField T="float" Value="hb.MinDropDelta"
                                                                             ValueChanged="@((float v) => { hb.MinDropDelta = v; QueueSave(); })"
                                                                             Label="Min Drop Delta" Variant="Variant.Outlined"
                                                                             Min="0.01f" Max="1f" Step="0.01f" Format="F2"
                                                                             HelperText="Trigger when fill drops this much below the baseline" />
                                                        </MudItem>
                                                        <MudItem xs="6">
                                                            <MudNumericField T="float" Value="hb.BaselineDecay"
                                                                             ValueChanged="@((float v) => { hb.BaselineDecay = v; QueueSave(); })"
                                                                             Label="Baseline Decay" Variant="Variant.Outlined"
                                                                             Min="0f" Max="1f" Step="0.005f" Format="F3"
                                                                             HelperText="0 = sticky baseline; small values forget slow drains" />
                                                        </MudItem>
                                                    </MudGrid>
                                                    break;
                                                case OnnxSettings onnx:
                                                    <MudGrid Spacing="2">
                                                        <MudItem xs="6">
                                                            <MudTextField Value="onnx.ModelPath"
                                                                          ValueChanged="@((string v) => { onnx.ModelPath = v; QueueSave(); })"
                                                                          Label="Model Path (.onnx)" Variant="Variant.Outlined" />
                                                        </MudItem>
                                                        <MudItem xs="3">
                                                            <MudTextField Value="onnx.Label"
                                                                          ValueChanged="@((string v) => { onnx.Label = v; QueueSave(); })"
                                                                          Label="Target Label" Variant="Variant.Outlined" />
                                                        </MudItem>
                                                        <MudItem xs="3">
                                                            <MudNumericField T="float" Value="onnx.Threshold"
                                                                             ValueChanged="@((float v) => { onnx.Threshold = v; QueueSave(); })"
                                                                             Label="Threshold" Variant="Variant.Outlined"
                                                                             Min="0f" Max="1f" Step="0.05f" Format="F2" />
                                                        </MudItem>
                                                    </MudGrid>
                                                    break;
                                            }
                                        </MudItem>
                                    </MudGrid>
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
            </MudCardContent>
        </MudCard>

        @* Actions *@
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.h6">Actions</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   OnClick="AddAction" StartIcon="@Icons.Material.Filled.Add">
                            Add Action
                        </MudButton>
                    </MudStack>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_profile.Actions.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        No actions configured. Add one to map events to shock controls.
                    </MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>Control Type</th>
                                <th>Intensity</th>
                                <th>Duration (ms)</th>
                                <th>Cooldown (ms)</th>
                                <th style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _profile.Actions.Count; i++)
                            {
                                var action = _profile.Actions[i];
                                var actionIdx = i;
                                <tr>
                                    <td>
                                        <MudTextField T="string" Value="action.EventType"
                                                      ValueChanged="@((string v) => { action.EventType = v; QueueSave(); })"
                                                      Variant="Variant.Text" Margin="Margin.Dense" />
                                    </td>
                                    <td>
                                        <MudSelect T="ControlType" Value="action.ControlType"
                                                   ValueChanged="@((ControlType v) => { action.ControlType = v; QueueSave(); })"
                                                   Variant="Variant.Text" Margin="Margin.Dense" Underline="false">
                                            @foreach (var ct in Enum.GetValues<ControlType>())
                                            {
                                                <MudSelectItem Value="ct">@ct</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </td>
                                    <td>
                                        <MudNumericField T="byte" Value="action.Intensity"
                                                         ValueChanged="@((byte v) => { action.Intensity = v; QueueSave(); })"
                                                         Variant="Variant.Text" Margin="Margin.Dense" HideSpinButtons="true"
                                                         Min="(byte)1" Max="(byte)100" />
                                    </td>
                                    <td>
                                        <MudNumericField T="ushort" Value="action.Duration"
                                                         ValueChanged="@((ushort v) => { action.Duration = v; QueueSave(); })"
                                                         Variant="Variant.Text" Margin="Margin.Dense" HideSpinButtons="true"
                                                         Min="(ushort)300" Max="(ushort)30000" />
                                    </td>
                                    <td>
                                        <MudNumericField T="int" Value="action.CooldownMs"
                                                         ValueChanged="@((int v) => { action.CooldownMs = v; QueueSave(); })"
                                                         Variant="Variant.Text" Margin="Margin.Dense" HideSpinButtons="true"
                                                         Min="100" Max="60000" />
                                    </td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                       Size="Size.Small" OnClick="() => RemoveAction(actionIdx)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudCardContent>
        </MudCard>
    }

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <MudAlert Severity="@_statusSeverity" ShowCloseIcon="true" CloseIconClicked="() => _statusMessage = null">
            @_statusMessage
        </MudAlert>
    }
</MudStack>

@code {
    [ModuleInject] private GameProfileManager ProfileManager { get; set; } = null!;
    [ModuleInject] private PreviewService PreviewService { get; set; } = null!;
    [ModuleInject] private ScreenCaptureService ScreenCapture { get; set; } = null!;
    [ModuleInject] private IModuleConfig<SentryConfig> ModuleConfig { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private List<string> _profiles = [];
    private string? _selectedProfile;
    private EditableGameProfile? _profile;
    private string? _previewDataUri;
    private int _selectedDetectorIndex = -1;
    private string? _statusMessage;
    private Severity _statusSeverity = Severity.Info;
    private RegionPreview? _regionPreview;
    private List<RegionPreview.RegionItem> _regionItems = [];

    private static readonly string[] _regionColors = ["#00c8ff", "#00ff80", "#8000ff", "#ff8000", "#ff0080"];

    protected override void OnInitialized()
    {
        RefreshProfiles();
    }

    private void RefreshProfiles()
    {
        _profiles = ProfileManager.ListProfiles().ToList();
    }

    private void OnProfileSelected(string profileName)
    {
        _selectedProfile = profileName;
        if (string.IsNullOrEmpty(profileName)) { _profile = null; _regionItems = []; return; }

        var loaded = ProfileManager.Load(profileName);
        _profile = loaded is not null ? EditableGameProfile.From(loaded) : null;
        SyncRegionItems();
    }

    private void NewProfile()
    {
        var name = "new-profile";
        _profile = new EditableGameProfile { Name = "New Profile" };
        ProfileManager.Save(name, _profile.ToGameProfile());
        _selectedProfile = name;
        RefreshProfiles();
        _regionItems = [];
    }

    private void DeleteProfile()
    {
        if (string.IsNullOrEmpty(_selectedProfile)) return;
        ProfileManager.Delete(_selectedProfile);
        _profile = null;
        _selectedProfile = null;
        RefreshProfiles();
        SetStatus("Profile deleted.", Severity.Info);
    }

    private void QueueSave()
    {
        if (_profile is null || string.IsNullOrEmpty(_selectedProfile)) return;
        ProfileManager.SaveDebounced(_selectedProfile, _profile.ToGameProfile());
    }

    private void CapturePreview()
    {
        if (ScreenCapture.ScreenWidth == 0)
        {
            var deviceName = ModuleConfig.Config.MonitorDeviceName;
            var monitor = !string.IsNullOrEmpty(deviceName)
                ? ScreenCaptureService.GetMonitors().FirstOrDefault(m => m.DeviceName == deviceName)
                : null;
            if (monitor is not null)
                ScreenCapture.Initialize(monitor.Bounds);
            else
                ScreenCapture.Initialize(ModuleConfig.Config.ScreenWidth, ModuleConfig.Config.ScreenHeight);
        }
        PreviewService.PreviewScale = 1f;
        _previewDataUri = PreviewService.CapturePreviewFrame();
        SyncRegionItems();
    }

    private async Task AddDetector()
    {
        _profile?.Detectors.Add(new EditableDetectorConfig
        {
            Name = $"Detector {(_profile!.Detectors.Count + 1)}",
            Backend = DetectorBackendType.OpenCvTemplate,
            Region = new NormalizedRegion { X = 0.1f, Y = 0.1f, Width = 0.2f, Height = 0.1f },
            EventType = "damage",
            _expanded = true
        });
        SyncRegionItems();
        QueueSave();
        if (_regionPreview is not null) await _regionPreview.RefreshRegions();
    }

    private async Task RemoveDetector(int index)
    {
        if (_profile is null || index < 0 || index >= _profile.Detectors.Count) return;
        _profile.Detectors.RemoveAt(index);
        SyncRegionItems();
        QueueSave();
        if (_regionPreview is not null) await _regionPreview.RefreshRegions();
    }

    private void SyncRegionItems()
    {
        if (_profile is null) { _regionItems = []; return; }
        _regionItems = _profile.Detectors.Select((d, i) => new RegionPreview.RegionItem
        {
            X = d.Region.X,
            Y = d.Region.Y,
            Width = d.Region.Width,
            Height = d.Region.Height,
            Label = d.Name,
            Color = _regionColors[i % _regionColors.Length]
        }).ToList();
    }

    private Task OnRegionDragged(RegionPreview.RegionChangedArgs args)
    {
        if (_profile is null || args.Index < 0 || args.Index >= _profile.Detectors.Count) return Task.CompletedTask;
        var detector = _profile.Detectors[args.Index];
        detector.Region.X = args.X;
        detector.Region.Y = args.Y;
        detector.Region.Width = args.Width;
        detector.Region.Height = args.Height;
        if (args.Index < _regionItems.Count)
        {
            _regionItems[args.Index].X = args.X;
            _regionItems[args.Index].Y = args.Y;
            _regionItems[args.Index].Width = args.Width;
            _regionItems[args.Index].Height = args.Height;
        }
        QueueSave();
        return Task.CompletedTask;
    }

    private void OnRegionClicked(int index)
    {
        _selectedDetectorIndex = index;
    }

    private async Task OnRegionFieldChanged(EditableDetectorConfig detector, Action<NormalizedRegion> apply)
    {
        apply(detector.Region);
        SyncRegionItems();
        QueueSave();
        if (_regionPreview is not null) await _regionPreview.RefreshRegions();
    }

    private async Task OnDetectorNameChanged(EditableDetectorConfig detector, string name)
    {
        detector.Name = name;
        SyncRegionItems();
        QueueSave();
        if (_regionPreview is not null) await _regionPreview.RefreshRegions();
    }

    private void AddAction()
    {
        _profile?.Actions.Add(new ActionMapping
        {
            EventType = "damage",
            ControlType = ControlType.Shock,
            Intensity = 30,
            Duration = 500,
            CooldownMs = 2000
        });
        QueueSave();
    }

    private void RemoveAction(int index)
    {
        if (_profile is null || index < 0 || index >= _profile.Actions.Count) return;
        _profile.Actions.RemoveAt(index);
        QueueSave();
    }

    private static readonly JsonSerializerOptions ExportJsonOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter(JsonNamingPolicy.CamelCase) }
    };

    private async Task ExportProfile()
    {
        if (_profile is null || string.IsNullOrEmpty(_selectedProfile)) return;
        try
        {
            var json = JsonSerializer.Serialize(_profile.ToGameProfile(), ExportJsonOptions);

            using var ms = new MemoryStream();
            using (var zip = new ZipArchive(ms, ZipArchiveMode.Create, leaveOpen: true))
            {
                var jsonEntry = zip.CreateEntry("profile.json", CompressionLevel.Optimal);
                await using (var es = jsonEntry.Open())
                await using (var sw = new StreamWriter(es))
                    await sw.WriteAsync(json);

                var baseDir = ProfileManager.GetProfileBaseDir(_selectedProfile);
                if (Directory.Exists(baseDir))
                {
                    foreach (var file in Directory.EnumerateFiles(baseDir))
                    {
                        var entry = zip.CreateEntry($"assets/{Path.GetFileName(file)}", CompressionLevel.Optimal);
                        await using var es = entry.Open();
                        await using var fs = File.OpenRead(file);
                        await fs.CopyToAsync(es);
                    }
                }
            }

            var fileName = $"{_selectedProfile}.sentryprofile";
            var base64 = Convert.ToBase64String(ms.ToArray());
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/octet-stream;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();");
        }
        catch (Exception ex)
        {
            SetStatus($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportProfile(IBrowserFile? file)
    {
        if (file is null) return;
        try
        {
            // Buffer to memory so we can detect format and seek.
            using var ms = new MemoryStream();
            await using (var stream = file.OpenReadStream(maxAllowedSize: 64 * 1024 * 1024))
                await stream.CopyToAsync(ms);
            ms.Position = 0;

            var saveName = Path.GetFileNameWithoutExtension(file.Name);
            GameProfile? profile = null;

            // Detect zip by PK header
            var isZip = ms.Length > 4 && ms.GetBuffer()[0] == 'P' && ms.GetBuffer()[1] == 'K';
            if (isZip)
            {
                using var zip = new ZipArchive(ms, ZipArchiveMode.Read);
                var jsonEntry = zip.GetEntry("profile.json")
                    ?? zip.Entries.FirstOrDefault(e => e.FullName.EndsWith(".json", StringComparison.OrdinalIgnoreCase));
                if (jsonEntry is null)
                {
                    SetStatus("Archive missing profile.json.", Severity.Error);
                    return;
                }

                await using (var js = jsonEntry.Open())
                    profile = await JsonSerializer.DeserializeAsync<GameProfile>(js, ExportJsonOptions);

                if (profile is null) { SetStatus("Invalid profile file.", Severity.Error); return; }

                ProfileManager.Save(saveName, profile);

                var baseDir = ProfileManager.GetProfileBaseDir(saveName);
                foreach (var entry in zip.Entries)
                {
                    if (entry.FullName.Equals("profile.json", StringComparison.OrdinalIgnoreCase)) continue;
                    if (string.IsNullOrEmpty(entry.Name)) continue; // directory
                    var dest = Path.Combine(baseDir, entry.Name);
                    await using var es = entry.Open();
                    await using var fs = File.Create(dest);
                    await es.CopyToAsync(fs);
                }

                // Re-save so cleanup keeps only referenced assets.
                ProfileManager.Save(saveName, profile);
            }
            else
            {
                ms.Position = 0;
                profile = await JsonSerializer.DeserializeAsync<GameProfile>(ms, ExportJsonOptions);
                if (profile is null) { SetStatus("Invalid profile file.", Severity.Error); return; }
                ProfileManager.Save(saveName, profile);
            }

            RefreshProfiles();
            _selectedProfile = saveName;
            _profile = EditableGameProfile.From(profile);
            SyncRegionItems();
            SetStatus($"Imported '{saveName}'", Severity.Success);
        }
        catch (Exception ex)
        {
            SetStatus($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private void SetStatus(string msg, Severity sev) { _statusMessage = msg; _statusSeverity = sev; }

    private async Task ImportTemplateImage(EditableDetectorConfig detector, IBrowserFile? file)
    {
        if (file is null || string.IsNullOrEmpty(_selectedProfile)) return;
        try
        {
            var baseDir = ProfileManager.GetProfileBaseDir(_selectedProfile);
            var safeName = string.Concat(file.Name.Split(Path.GetInvalidFileNameChars()));
            var destPath = Path.Combine(baseDir, safeName);
            await using (var src = file.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024))
            await using (var dst = File.Create(destPath))
            {
                await src.CopyToAsync(dst);
            }
            switch (detector.Settings)
            {
                case OpenCvTemplateSettings t: t.TemplatePath = safeName; break;
                case OpenCvSiftSettings s: s.TemplatePath = safeName; break;
            }
            QueueSave();
            SetStatus($"Imported template '{safeName}'", Severity.Success);
        }
        catch (Exception ex)
        {
            SetStatus($"Template import failed: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetBackendColor(DetectorBackendType b) => b switch
    {
        DetectorBackendType.OpenCvTemplate => Color.Primary,
        DetectorBackendType.OpenCvSift => Color.Secondary,
        DetectorBackendType.Ocr => Color.Tertiary,
        DetectorBackendType.Onnx => Color.Warning,
        DetectorBackendType.HealthBar => Color.Success,
        _ => Color.Default
    };

