@using OpenShock.Sentry.Services

<MudStack Spacing="3" Class="pa-4">

    <MudText Typo="Typo.h5">Settings</MudText>

    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-3">Screen Capture</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudSelect T="string" Label="Monitor" Value="_selectedMonitor"
                               ValueChanged="OnMonitorChanged"
                               Variant="Variant.Outlined">
                        @foreach (var m in _monitors)
                        {
                            <MudSelectItem Value="@m.DeviceName">@m.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" @bind-Value="_targetCaptureFps" Label="Target FPS"
                                     Variant="Variant.Outlined" Min="1" Max="240" />
                </MudItem>
                <MudItem xs="4" Class="d-flex align-center">
                    <MudText Typo="Typo.body2" Color="Color.Tertiary">
                        @if (_selectedMonitorInfo is not null)
                        {
                            @($"{_selectedMonitorInfo.Width}x{_selectedMonitorInfo.Height} at ({_selectedMonitorInfo.X}, {_selectedMonitorInfo.Y})")
                        }
                    </MudText>
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" Class="mt-3">
                Save
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="RefreshMonitors" Class="mt-3 ml-2"
                       StartIcon="@Icons.Material.Filled.Refresh">
                Refresh Monitors
            </MudButton>
        </MudCardContent>
    </MudCard>

    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-3">Data Directory</MudText>
            <MudText Typo="Typo.body2">
                Profiles and configuration are stored in:<br />
                <code>@_dataDir</code>
            </MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2"
                       OnClick="OpenDataDir" StartIcon="@Icons.Material.Filled.FolderOpen">
                Open in Explorer
            </MudButton>
        </MudCardContent>
    </MudCard>

    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-3">About</MudText>
            <MudText Typo="Typo.body2">
                OpenShock Sentry — screen-based game event detection module.
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Tertiary">
                Supports OpenCV template matching, SIFT feature detection, OCR, and ONNX inference backends.
            </MudText>
        </MudCardContent>
    </MudCard>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <MudAlert Severity="@_statusSeverity" ShowCloseIcon="true" CloseIconClicked="() => _statusMessage = null">
            @_statusMessage
        </MudAlert>
    }
</MudStack>

@code {
    [ModuleInject] private IModuleConfig<SentryConfig> ModuleConfig { get; set; } = null!;

    private List<MonitorInfo> _monitors = [];
    private string? _selectedMonitor;
    private MonitorInfo? _selectedMonitorInfo;
    private int _targetCaptureFps;
    private string _dataDir = "";
    private string? _statusMessage;
    private Severity _statusSeverity;

    protected override void OnInitialized()
    {
        _targetCaptureFps = ModuleConfig.Config.TargetCaptureFps;
        RefreshMonitors();

        // Restore saved monitor or default to primary
        if (!string.IsNullOrEmpty(ModuleConfig.Config.MonitorDeviceName)
            && _monitors.Any(m => m.DeviceName == ModuleConfig.Config.MonitorDeviceName))
        {
            SelectMonitor(ModuleConfig.Config.MonitorDeviceName);
        }
        else
        {
            var primary = _monitors.FirstOrDefault(m => m.IsPrimary) ?? _monitors.FirstOrDefault();
            if (primary is not null)
                SelectMonitor(primary.DeviceName);
        }

        _dataDir = Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData),
            "OpenShock", "Desktop", "moduleData", "openshock.sentry");
    }

    private void RefreshMonitors()
    {
        _monitors = ScreenCaptureService.GetMonitors();
    }

    private void OnMonitorChanged(string deviceName)
    {
        SelectMonitor(deviceName);
    }

    private void SelectMonitor(string deviceName)
    {
        _selectedMonitor = deviceName;
        _selectedMonitorInfo = _monitors.FirstOrDefault(m => m.DeviceName == deviceName);
    }

    private void SaveSettings()
    {
        if (_selectedMonitorInfo is not null)
        {
            ModuleConfig.Config.MonitorDeviceName = _selectedMonitorInfo.DeviceName;
            ModuleConfig.Config.ScreenWidth = _selectedMonitorInfo.Width;
            ModuleConfig.Config.ScreenHeight = _selectedMonitorInfo.Height;
        }
        ModuleConfig.Config.TargetCaptureFps = _targetCaptureFps;
        ModuleConfig.SaveDeferred();
        _statusMessage = "Settings saved.";
        _statusSeverity = Severity.Success;
    }

    private void OpenDataDir()
    {
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
            {
                FileName = _dataDir,
                UseShellExecute = true
            });
        }
        catch { }
    }
}
